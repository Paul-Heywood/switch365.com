                  <td>1.49%</td>
                  <td><strong>1.70%</strong></td>
                  <td><strong>+0.21%</strong></td>
                </tr>
                <tr>
                  <td>£2K/month turnover; 100 transactions; mobile reader</td>
                  <td>1.75%</td>
                  <td><strong>3.10%</strong></td>
                  <td><strong>+1.35%</strong></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <div class="mb-8">
